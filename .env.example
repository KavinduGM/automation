# ─────────────────────────────────────────────────────────────────────────────
# Content Automation — environment template
# Copy to `.env` and fill in. See README §"Getting your API keys" for how.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ───────────────────────────────────────────────────────────────────
NODE_ENV=production
TZ=UTC
LOG_LEVEL=info

# Public URLs (used for OAuth redirects, signed approval links, etc.)
DASHBOARD_URL=https://automation.groovymark.com
DASHBOARD_PORT=3000

# Base URL where client sites fetch automation-generated images/videos.
# Routed by Dokploy's Traefik to the `assets` service. Configure that
# mapping in the Dokploy UI: domain `assets.<yours>` → service `assets`
# → port 80.
ASSETS_PUBLIC_URL=https://assets.groovymark.com

# ── Database ───────────────────────────────────────────────────────────────
# If you keep the postgres service in docker-compose, leave host as `postgres`.
POSTGRES_USER=ca
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_STRING
POSTGRES_DB=ca
DATABASE_URL=postgresql://ca:CHANGE_ME_LONG_RANDOM_STRING@postgres:5432/ca?schema=public

# ── Redis (BullMQ) ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Secrets ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=
TOKEN_ENCRYPTION_KEY=

# Comma-separated allowlist of emails that may sign in to the dashboard.
ALLOWED_LOGIN_EMAILS=you@yourdomain.com

# ── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM="Content Automation <automation@groovymark.com>"
APPROVAL_DIGEST_TO=you@yourdomain.com

# ── AI / Content APIs ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_WRITING=claude-sonnet-4-6
ANTHROPIC_MODEL_ROUTING=claude-haiku-4-5

OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1

ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=

HEYGEN_API_KEY=
HEYGEN_DEFAULT_AVATAR_ID=
HEYGEN_DEFAULT_VOICE_ID=

CANVA_API_KEY=

# ── Social scheduling (Buffer) ─────────────────────────────────────────────
BUFFER_ACCESS_TOKEN=

# ── Trend sources ──────────────────────────────────────────────────────────
GROK_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=content-automation/0.1 (by /u/yourusername)

# ── YouTube Automation (separate service) ──────────────────────────────────
# Base URL of your existing YT Automation API (apps/api).
YT_AUTOMATION_API_URL=http://yt-api:4000
# Bearer token you'll add to YT API (we'll generate this in setup).
YT_AUTOMATION_API_TOKEN=
# Local directory that's rclone-synced to the YT Automation Drive folder.
# Short videos are copied here with the channel-prefixed filename after render,
# and the YT Automation Drive watcher picks them up. Leave blank to skip the
# copy step (you'd then upload via Drive API directly — not implemented yet).
YT_DRIVE_DROP_DIR=/app/assets/yt-drive-drop

# ── Video renderer service ─────────────────────────────────────────────────
# Internal URL the worker uses to reach the video-renderer container.
VIDEO_RENDERER_URL=http://video-renderer:4100
# Shared secret between worker and renderer (sent as X-Renderer-Token header).
# Leave blank during local dev to skip auth; SET IN PROD.
RENDERER_AUTH_TOKEN=

# ── Native YouTube publish (replaces YT Automation hop for new businesses) ─
# Google Cloud Console → OAuth 2.0 client → Web application.
# Authorized redirect URI must include: ${DASHBOARD_URL}/api/youtube/oauth/callback
# Consent screen tip: User type = Internal (if you have Workspace) avoids
# the 7-day refresh-token expiry and skips Google verification entirely.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Short-video pipeline kill switch ──────────────────────────────────────
# SAFETY LOCK. Set to "true" (or "1") to disable ALL Claude calls related to
# short videos. Affects auto-trigger after blog publish, the "Generate scripts
# now" button on the Shorts page, the "Test now" button on the business page,
# and the render + publish queue handlers. Use this while the renderer is
# being migrated to a different host (Mac mini) so accidental clicks or
# automated triggers don't burn Claude credits. Leave empty (default) to
# allow normal operation.
SHORTVIDEO_DISABLED=

# ── ElevenLabs (TTS for short-form video narration) ────────────────────────
ELEVENLABS_API_KEY=
# Default voice ID — overridden per-business via the dashboard's short-video plan.
ELEVENLABS_DEFAULT_VOICE_ID=

# ── Assets & backups ───────────────────────────────────────────────────────
ASSETS_DIR=/app/assets
TMP_DIR=/app/tmp

# Backblaze B2 (optional but recommended)
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
B2_ENDPOINT=https://s3.us-west-001.backblazeb2.com

# ── Tuning ─────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=4
SCHEDULER_TICK_SECONDS=60
RESEARCH_CRON=0 4 * * *
DIGEST_CRON=0 9,13,17 * * *
